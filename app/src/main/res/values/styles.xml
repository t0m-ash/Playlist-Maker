<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="MainButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textAllCaps">false</item>
        <item name="iconTint">@color/black</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_22</item>
        <item name="cornerRadius">@dimen/main_btn_radius_16</item>
        <item name="android:textFontWeight">500</item>
    </style>

    <style name="SwitchStyle">
        <item name="thumbTint">@color/blue</item>
        <item name="trackTint">@color/blue_light</item>
    </style>

    <style name="TextViewSettingsStyle">
        <item name="android:textColor">@color/text_black</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">@dimen/text_size_16</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="ImageButtonSettingsStyle">
        <item name="android:layout_width">@dimen/ib_width_24</item>
        <item name="android:layout_height">@dimen/ib_height_24</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
    </style>

    <style name="TopBarStyle">
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_height">@dimen/bar_56</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/text_size_22</item>
    </style>

    <style name="TopBarTitleStyle" parent="TopBarStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/text_size_22</item>
    </style>

    <style name="TopBarIconButtonStyle" parent="TopBarStyle">
        <item name="android:layout_width">@dimen/ib_with_48</item>
        <item name="android:layout_height">@dimen/ib_height_48dp</item>
        <item name="android:layout_margin">@dimen/ib_bar_margin_4</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="SearchBarContainerStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginHorizontal">@dimen/search_field_margin_horizontal</item>
        <item name="android:layout_marginVertical">@dimen/search_field_margin_vertical</item>
    </style>

    <style name="SearchBarEditTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/search_field_height</item>
        <item name="android:background">@drawable/search_bar</item>
        <item name="android:drawableStart">@drawable/ic_search_16</item>
        <item name="android:drawablePadding">@dimen/search_field_drawable_padding</item>
        <item name="android:inputType">text</item>
        <item name="android:maxLines">1</item>
        <item name="android:paddingStart">@dimen/search_field_padding_start</item>
        <item name="android:paddingEnd">@dimen/search_field_padding_end</item>
        <item name="android:textCursorDrawable">@drawable/cursor_blue</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/text_gray</item>
        <item name="android:drawableTint">@color/text_gray</item>
    </style>

    <style name="SearchBarClearIconStyle">
        <item name="android:layout_width">@dimen/clear_icon_width</item>
        <item name="android:layout_height">@dimen/clear_icon_height</item>
        <item name="android:layout_gravity">end|center_vertical</item>
        <item name="android:paddingHorizontal">@dimen/clear_icon_padding_horizontal</item>
        <item name="android:paddingVertical">@dimen/clear_icon_padding_vertical</item>
        <item name="android:visibility">gone</item>
    </style>

    <style name="TrackNameStyle">
        <item name="android:textColor">@color/track_title</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">@dimen/text_size_16</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="TrackSubtitleStyle">
        <item name="android:textColor">@color/track_subtitle</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">@dimen/text_size_11</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="PlaceholderMessageStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/track_title</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_19</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="SearchHistoryTitleStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/track_title</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_19</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ActionButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:backgroundTint">@color/action_button_background</item>
        <item name="android:textColor">@color/action_button_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_14</item>
        <item name="android:paddingHorizontal">@dimen/refresh_button_padding_horizontal</item>
        <item name="cornerRadius">@dimen/main_btn_radius_16</item>
        <item name="android:textFontWeight">500</item>
    </style>
</resources>