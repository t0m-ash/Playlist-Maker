<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_activity_background"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/bar_56"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_back"
            style="@style/TopBarIconButtonStyle"
            android:src="@drawable/ic_arrow_back_24"
            android:visibility="gone" />

        <TextView
            style="@style/TopBarTitleStyle"
            android:layout_marginStart="16dp"
            android:text="@string/app_name"
            android:textColor="@color/white" />

        <ImageButton
            style="@style/TopBarIconButtonStyle"
            android:gravity="center_horizontal"
            android:src="@drawable/ic_filter_24"
            android:visibility="invisible" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_search"
        style="@style/MainButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/main_btn_start"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="@dimen/main_btn_end"
        android:layout_weight="1"
        android:text="@string/search"
        app:icon="@drawable/ic_search_24"
        app:iconGravity="textStart"
        app:iconPadding="10dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_library"
        style="@style/MainButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/main_btn_start"
        android:layout_marginTop="@dimen/main_btn_top"
        android:layout_marginEnd="@dimen/main_btn_end"
        android:layout_weight="1"
        android:text="@string/library"
        app:icon="@drawable/ic_library_24"
        app:iconGravity="textStart"
        app:iconPadding="10dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_settings"
        style="@style/MainButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/main_btn_start"
        android:layout_marginTop="@dimen/main_btn_top"
        android:layout_marginEnd="@dimen/main_btn_end"
        android:layout_marginBottom="28dp"
        android:layout_weight="1"
        android:text="@string/settings"
        app:icon="@drawable/ic_settings_24"
        app:iconGravity="textStart"
        app:iconPadding="8dp" />
</LinearLayout>