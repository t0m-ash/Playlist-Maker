<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".SearchActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/bar_56"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/ib_with_48"
            android:layout_height="@dimen/ib_height_48dp"
            android:layout_margin="@dimen/ib_bar_margin_4"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_back_24" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="26dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="@font/ys_display_medium"
            android:text="@string/search"
            android:textColor="@color/black"
            android:textFontWeight="500"
            android:textSize="@dimen/text_medium_22" />

        <ImageButton
            android:layout_width="@dimen/ib_with_48"
            android:layout_height="@dimen/ib_height_48dp"
            android:layout_margin="@dimen/ib_bar_margin_4"
            android:gravity="center_horizontal"
            android:src="@drawable/ic_filter_24"
            android:visibility="invisible" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="8dp">

        <EditText
            android:id="@+id/searchEditText"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/search_bar"
            android:drawableStart="@drawable/ic_search_16"
            android:drawablePadding="9dp"
            android:hint="@string/search"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="12dp"
            android:paddingEnd="36dp"
            android:textCursorDrawable="@drawable/cursor_blue" />

        <ImageView
            android:id="@+id/clearIcon"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:layout_gravity="end|center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:src="@drawable/ic_clear_16"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>