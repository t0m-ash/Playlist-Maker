<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TopBarStyle">
        <item name="android:textColor">@color/white</item>
        <item name="android:tint">@color/white</item>
    </style>

    <style name="TextViewSettingsStyle">
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">@dimen/text_size_16</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="ImageButtonSettingsStyle">
        <item name="android:tint">@color/white</item>
        <item name="android:layout_width">@dimen/ib_width_24</item>
        <item name="android:layout_height">@dimen/ib_height_24</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
    </style>

    <style name="SwitchStyle">
        <item name="thumbTint">@color/blue</item>
        <item name="trackTint">@color/blue_light</item>
    </style>

    <style name="SearchBarEditTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/search_field_height</item>
        <item name="android:background">@drawable/search_bar</item>
        <item name="android:drawableStart">@drawable/ic_search_16</item>
        <item name="android:drawablePadding">@dimen/search_field_drawable_padding</item>
        <item name="android:inputType">text</item>
        <item name="android:maxLines">1</item>
        <item name="android:paddingStart">@dimen/search_field_padding_start</item>
        <item name="android:paddingEnd">@dimen/search_field_padding_end</item>
        <item name="android:textCursorDrawable">@drawable/cursor_blue</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/black</item>
        <item name="android:drawableTint">@color/black</item>
    </style>

    <style name="SearchBarClearIconStyle">
        <item name="android:layout_width">@dimen/clear_icon_width</item>
        <item name="android:layout_height">@dimen/clear_icon_height</item>
        <item name="android:layout_gravity">end|center_vertical</item>
        <item name="android:paddingHorizontal">@dimen/clear_icon_padding_horizontal</item>
        <item name="android:paddingVertical">@dimen/clear_icon_padding_vertical</item>
        <item name="android:visibility">gone</item>
        <item name="android:tint">@color/black</item>
    </style>
</resources>